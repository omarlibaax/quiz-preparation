PORT=4000
# phpMyAdmin / XAMPP: create DB `exam_platform` first, then match user/password here:
DATABASE_URL="mysql://root:@localhost:3306/exam_platform"
JWT_ACCESS_SECRET="replace-with-long-access-secret"
JWT_REFRESH_SECRET="replace-with-long-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS=7
ADMIN_BOOTSTRAP_SECRET="replace-with-bootstrap-secret"

# Optional: create Super Admin via `npm run create-super-admin`
SUPER_ADMIN_EMAIL="superadmin@example.com"
SUPER_ADMIN_PASSWORD="change-me-8-chars-min"
SUPER_ADMIN_FULL_NAME="Super Admin"

# Full seed: users + import questions.json → DB (`npx prisma db seed` from server/)
# Defaults shown; change passwords in production.
SEED_SUPER_ADMIN_EMAIL="superadmin@exam.local"
SEED_SUPER_ADMIN_PASSWORD="SuperAdmin123!"
SEED_SUPER_ADMIN_NAME="Super Admin"
SEED_ADMIN_EMAIL="admin@exam.local"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_ADMIN_NAME="Platform Admin"
SEED_STUDENT_EMAIL="student@exam.local"
SEED_STUDENT_PASSWORD="Student123!"
SEED_STUDENT_NAME="Demo Student"
# SEED_CLEAR=true   # wipe subjects/topics/questions then re-import JSON (keeps users)
# SEED_IMPORT_BANK=false  # only create/update users, skip JSON import

